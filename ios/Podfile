require 'fileutils'

platform :ios, '13.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line| 
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  pod 'AgoraRtcEngine_iOS'
  pod 'Clarity'
  pod 'TikTokBusinessSDK'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

# Agora dynamic frameworks handling. Agora pods expect their xcframeworks to be embedded
# so we should force them to build as dynamic frameworks even when static linking is enabled.
dynamic_frameworks = ['agora_rtc_engine', 'iris_method_channel', 'AgoraIrisRTC_iOS', 'AgoraRtcEngine_iOS']

pre_install do |installer|
  # Disable the static framework validation that breaks Flutter builds
  Pod::Installer::Xcode::TargetValidator.send(:define_method, :verify_no_static_framework_transitive_dependencies) {}

  installer.pod_targets.each do |target|
    if dynamic_frameworks.include? target.name
      puts "Installing dynamic framework: #{target.name}"
      def target.build_type
        Pod::BuildType.dynamic_framework
      end
    end
  end
end

post_install do |installer|
  require 'fileutils'

  # Remove duplicate aosl.xcframework in Agora pods
  agora_pods = ['AgoraInfra_iOS', 'AgoraIrisRTC_iOS', 'AgoraIrisRTM_iOS', 'AgoraRtm']
  agora_pods.each do |pod_name|
    aosl_path = File.join(installer.sandbox.root, "Pods/#{pod_name}/aosl.xcframework")
    if File.directory?(aosl_path)
      puts "Removing duplicate aosl.xcframework from #{pod_name}"
      FileUtils.rm_rf(aosl_path)
    end
  end

  # Apply global build settings
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['STRIP_STYLE'] = 'non-global'
      config.build_settings['COPY_PHASE_STRIP'] = 'YES'
      config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'YES'
      config.build_settings['STRIP_SWIFT_SYMBOLS'] = 'YES'
      config.build_settings['DEAD_CODE_STRIPPING'] = 'YES'
    end

    # Special handling for Agora
    if target.name.start_with?('Agora')
      target.build_configurations.each do |config|
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        config.build_settings['DEPLOYMENT_POSTPROCESSING'] = 'YES'
        config.build_settings['PRESERVE_DEAD_CODE_INITS_AND_TERMS'] = 'YES'
      end
    end
  end
end
